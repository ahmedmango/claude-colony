{
  "name": "claude-colony",
  "version": "0.1.0",
  "description": "Watch your Claude Code sessions work — a pixel-art ant colony that tails ~/.claude/projects/ and renders live sessions as ants crawling your filesystem.",
  "type": "module",
  "license": "MIT",
  "author": "Ahmed Haffadh",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmedmango/claude-colony"
  },
  "homepage": "https://github.com/ahmedmango/claude-colony",
  "bugs": "https://github.com/ahmedmango/claude-colony/issues",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "observability",
    "dashboard",
    "ant-colony",
    "pixel-art",
    "cli",
    "developer-tools"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "bin": {
    "claude-colony": "bin/colony.mjs"
  },
  "files": [
    "bin/",
    "server/",
    "public/",
    "skills/",
    "README.md",
    "ARCHITECTURE.md",
    "AUTH.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run server/index.ts",
    "start": "bun run server/index.ts",
    "start:bin": "node bin/colony.mjs",
    "doctor": "bun scripts/doctor.ts",
    "test": "bun test",
    "prepublishOnly": "bun test"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
